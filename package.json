{
  "name": "vancouver-home-value-planner",
  "private": true,
  "packageManager": "pnpm@9.15.2",
  "engines": {
    "node": "24.x",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "test": "pnpm -r test && .venv/bin/python -m pytest",
    "typecheck": "pnpm -r typecheck",
    "dev:model": ".venv/bin/python artifacts/model-service/app.py",
    "dev:api": "pnpm --filter @vvl/api-server dev",
    "dev:web": "pnpm --filter @vvl/home-value-planner dev"
  }
}
